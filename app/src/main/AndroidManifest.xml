<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_football_app"
        android:roundIcon="@drawable/ic_football_app"
        android:label="NickherCore"
        android:supportsRtl="true"
        android:theme="@style/Theme.NickherCore">

        <activity
            android:name=".AuthActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".NotificationActivity"
            android:exported="false" />

        <activity
            android:name=".StandingsActivity"
            android:exported="false" />

        <activity
            android:name=".MatchStatsActivity"
            android:exported="false" />

        <activity
            android:name=".MatchEventsActivity"
            android:exported="false" />

        <activity
            android:name=".AddMatchActivity"
            android:exported="false" />

        <activity
            android:name=".MatchDetailActivity"
            android:exported="false" />

        <activity
            android:name=".LineupPitchActivity"
            android:exported="false" />

    </application>

</manifest>