<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Thêm trận đấu"
            android:textColor="@color/text_dark"
            android:textSize="26sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtLeague"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/input_background"
            android:hint="Tên giải đấu"
            android:inputType="text" />

        <EditText
            android:id="@+id/edtHomeTeam"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/input_background"
            android:hint="Đội nhà"
            android:inputType="text" />

        <EditText
            android:id="@+id/edtAwayTeam"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/input_background"
            android:hint="Đội khách"
            android:inputType="text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edtHomeScore"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/input_background"
                android:hint="Tỷ số nhà"
                android:inputType="number" />

            <EditText
                android:id="@+id/edtAwayScore"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/input_background"
                android:hint="Tỷ số khách"
                android:inputType="number" />
        </LinearLayout>

        <EditText
            android:id="@+id/edtMatchTime"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/input_background"
            android:hint="Thời gian, ví dụ: 20:00"
            android:inputType="text" />

        <EditText
            android:id="@+id/edtStatus"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/input_background"
            android:hint="Trạng thái: Sắp diễn ra / Đang đá / FT"
            android:inputType="text" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/button_primary"
            android:text="Lưu trận đấu"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_secondary"
            android:text="Hủy"
            android:textAllCaps="false"
            android:textColor="@color/primary" />
    </LinearLayout>
</ScrollView>
